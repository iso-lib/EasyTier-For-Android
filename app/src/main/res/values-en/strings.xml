    <!-- Flags Help Texts -->
    <string name="help_relay_whitelist">Only forward traffic for whitelisted networks. Supports wildcards. Separate multiple networks with spaces. Empty to disable forwarding. E.g. \'*\' \'def*\' \'net1 net2\'</string>
    <string name="help_latency_first">Ignore relay hops and choose the path with the lowest total latency.</string>
    <string name="help_private_mode">Enable private mode. Only peers with matching network name and secret can handshake or relay through this node.</string>
    <string name="help_enable_kcp">Convert TCP traffic to KCP traffic to reduce latency and improve speed.</string>
    <string name="help_disable_kcp_input">Disable KCP input. Other peers will connect to this node using TCP.</string>
    <string name="help_disable_p2p">Disable P2P mode. All traffic will be relayed through manually specified servers.</string>
    <string name="help_no_tun">Do not create TUN interface. Useful when running without admin privileges. This node can only be accessed; accessing other nodes requires SOCKS5 proxy.</string>
    <string name="help_multi_thread">Run core services in multi-threaded mode, potentially improving performance.</string>
    <string name="help_accept_dns">Enable Magic DNS. Access other nodes in the network via \'hostname.et.net\'.</string>
    <string name="help_bind_device">Bind to physical network interface only, avoiding communication through other VPNs or virtual interfaces.</string>
    <string name="help_enable_exit_node">Allow this node to act as an exit node for other nodes, forwarding all their traffic to the public internet.</string>
    <string name="help_disable_encryption">Disable encryption between peers. WARNING: Insecure. Use only in trusted networks and ensure all nodes are configured consistently.</string>
    <string name="help_disable_ipv6">Disable IPv6 for this node. Only use IPv4 for network communication.</string>
    <string name="help_enable_quic">Convert TCP traffic to QUIC traffic to reduce latency and improve speed.</string>
    <string name="help_disable_quic_input">Disable QUIC input. Other peers will connect to this node using TCP.</string>
    <string name="help_disable_udp_hole_punching">Disable regular UDP hole punching. May affect P2P connection establishment.</string>
    <string name="help_disable_sym_hole_punching">Disable symmetric NAT hole punching (birthday attack). Treats it as simpler cone NAT.</string>
    <string name="help_relay_all_rpc">Allow forwarding all RPC packets from peers, even if not in the relay whitelist. Helps peers outside the whitelist establish P2P connections.</string>
    <string name="help_proxy_forward_by_system">Forward subnet proxy packets via OS kernel instead of built-in NAT.</string>
    <string name="help_use_smoltcp">Use user-space TCP/IP stack (smoltcp). Bypasses some OS firewall restrictions and improves compatibility for subnet proxy or KCP proxy.</string>
    <string name="help_manual_routes">Manually assign route CIDRs. Disables subnet proxy and WireGuard route propagation from peers. E.g. 192.168.0.0/16</string>
    <string name="help_socks5_server">Enable SOCKS5 server to allow clients to access the virtual network. Format: &lt;port&gt;, e.g. 1080</string>
    <string name="help_port_forward">Forward local ports to remote ports in the virtual network. E.g. udp://0.0.0.0:12345/10.126.126.1:23456 forwards local UDP 12345 to 10.126.126.1:23456. Multiple entries allowed.</string>
